<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:paddingVertical="10dp"
    android:layout_marginBottom="10dp"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="horizontal">

    <LinearLayout
        android:layout_marginStart="5dp"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">
        <TextView
            android:id="@+id/item_booking_patient_name"
            android:includeFontPadding="false"
            android:fontFamily="@font/poppins"
            android:textSize="@dimen/default_font_size"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="I Ordered a supplli"/>
        <TextView
            android:id="@+id/item_booking_date"
            android:includeFontPadding="false"
            android:fontFamily="@font/poppins"
            android:textSize="@dimen/default_font_size"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="I Ordered a supplli"/>
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <TextView
                android:id="@+id/item_booking_patient_city"
                android:textColor="@color/material_on_background_disabled"
                android:includeFontPadding="false"
                android:fontFamily="@font/poppins"
                android:textSize="13sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2023/10/01"/>
            <TextView
                android:textColor="@color/material_on_background_disabled"
                android:includeFontPadding="false"
                android:fontFamily="@font/poppins"
                android:textSize="13sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" | "/>
            <TextView
                android:id="@+id/item_booking_patient_number"
                android:textColor="@color/material_on_background_disabled"
                android:includeFontPadding="false"
                android:fontFamily="@font/poppins"
                android:textSize="13sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="order id: 123123"/>
        </LinearLayout>

        <androidx.cardview.widget.CardView
            android:id="@+id/item_booking_status_card"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/md_theme_surfaceBright"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">
            <TextView
                android:layout_marginHorizontal="@dimen/item_card_margin_horizontal"
                android:textAlignment="center"
                android:fontFamily="@font/poppins"
                android:id="@+id/item_booking_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="0dp"
                android:textColor="@color/stock_color"
                android:textSize="@dimen/small_font_size"
                android:text="In Stock" />

        </androidx.cardview.widget.CardView>

    </LinearLayout>
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:orientation="vertical">
        <TextView
            android:layout_weight="1"
            android:id="@+id/item_booking_time_slot"
            android:layout_gravity="end"
            android:includeFontPadding="false"
            android:fontFamily="@font/poppins"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rs.1200"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/item_booking_cancel_btn"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="Cancel"
            android:gravity="bottom"
            android:layout_gravity="bottom|end"
            android:fontFamily="@font/poppins"
            style="@style/Widget.Material3.Button.TonalButton" />
    </LinearLayout>



</LinearLayout>